DELIMITER $$

CREATE PROCEDURE merge_customers(IN p_city VARCHAR(100))
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE v_cust_id INT;
    DECLARE v_cust_name VARCHAR(100);
    DECLARE v_cust_city VARCHAR(100);
    DECLARE v_count INT;

    DECLARE cur_old CURSOR FOR 
        SELECT cust_id, cust_name, cust_city FROM Cust_Old WHERE cust_city = p_city;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

    OPEN cur_old;

    read_loop: LOOP
        FETCH cur_old INTO v_cust_id, v_cust_name, v_cust_city;
        IF done THEN
            LEAVE read_loop;
        END IF;

        SELECT COUNT(*) INTO v_count FROM Cust_New WHERE cust_id = v_cust_id;

        IF v_count = 0 THEN
            INSERT INTO Cust_New (cust_id, cust_name, cust_city)
            VALUES (v_cust_id, v_cust_name, v_cust_city);
            
            SELECT CONCAT('Inserted customer ID: ', v_cust_id) AS message;
        ELSE
            SELECT CONCAT('Duplicate found, skipping customer ID: ', v_cust_id) AS message;
        END IF;
    END LOOP;

    CLOSE cur_old;
END$$

