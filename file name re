-- 1. Create Department Table (The "Parent" table)
CREATE TABLE dept (
    dept_id INT AUTO_INCREMENT PRIMARY KEY,
    dept_name VARCHAR(50) NOT NULL UNIQUE
);

-- 2. Create Employee Table (The "Child" table with Foreign Key)
CREATE TABLE emp (
    emp_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(50) NOT NULL,
    salary DECIMAL(10, 2),
    d_id INT,
    FOREIGN KEY (d_id) REFERENCES dept(dept_id)
);

-- 3. Create an Index (Requirement: Index)
CREATE INDEX idx_emp_name ON emp(name);

-- 4. Create a Simple View (Requirement: View)
CREATE VIEW emp_details AS 
SELECT name, salary FROM emp;


-- 1. INSERT: Add multiple Departments
INSERT INTO dept (dept_name) VALUES ('IT'), ('HR'), ('Sales');

-- 2. INSERT: Add 5-6 Employees (linked to Dept IDs)
INSERT INTO emp (name, salary, d_id) VALUES 
('Aman', 50000, 1),
('Sainath', 55000, 1),
('Pranav', 45000, 2),
('Rahul', 60000, 3),
('Snehal', 48000, 2),
('Vijay', 52000, 1);

-- 3. SELECT with Alias: (Simulating Synonym)
SELECT e.name, e.salary FROM emp AS e;

-- 4. JOIN Query: Join emp and dept using Foreign Key
SELECT e.name, d.dept_name 
FROM emp AS e 
JOIN dept AS d ON e.d_id = d.dept_id;

-- 5. UPDATE with Operator: Give a 10% raise to IT dept (d_id=1)
UPDATE emp SET salary = salary * 1.10 WHERE d_id = 1;

-- 6. AGGREGATE Function: Find the average salary
SELECT AVG(salary) AS Average_Salary FROM emp;

-- 7. FILTERING: Find employees earning more than 50,000
SELECT * FROM emp WHERE salary > 50000;

-- 8. LIKE Operator: Search for names starting with 'A'
SELECT * FROM emp WHERE name LIKE 'A%';

-- 9. ORDER BY: List employees by salary (Highest first)
SELECT * FROM emp ORDER BY salary DESC;

-- 10. DELETE: Remove an employee
DELETE FROM emp WHERE emp_id = 5;

